# ============================================================
# Environment Variables — Kong AI Fraud Detection Platform
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is in .gitignore).
# ============================================================

# ── Kong Konnect ────────────────────────────────────────────
# Found in Konnect UI: Gateway Manager → <your Control Plane>
# → Overview tab → endpoints

# Control Plane endpoint (without https:// prefix)
# Example: abc123def456.cp0.konghq.com
KONNECT_CP_ENDPOINT=<your-cp-id>.cp0.konghq.com

# Telemetry endpoint (without https:// prefix)
# Example: abc123def456.tp0.konghq.com
KONNECT_TP_ENDPOINT=<your-cp-id>.tp0.konghq.com

# Personal Access Token — used by decK to sync config to Konnect
# Konnect UI: Account → Personal Access Tokens → Generate Token
KONNECT_PAT=kpat_XXXXXXXXXXXXXXXXXXXX

# Control Plane Name — used by decK commands
KONNECT_CONTROL_PLANE_NAME=fraud-platform-cp

# Konnect Region (us, eu, au, in, me)
KONNECT_REGION=us

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_in_prod

# ── Upstream URLs ────────────────────────────────────────────
# Local Docker Compose (default in kong/kong.yaml)
ACCOUNTS_UPSTREAM_URL=http://accounts-service:8080
TRANSACTIONS_UPSTREAM_URL=http://transactions-service:8080

# AWS EKS (switch to these after Phase 1 EKS deployment)
# ACCOUNTS_UPSTREAM_URL=http://accounts-service.fintech-services.svc.cluster.local:8080
# TRANSACTIONS_UPSTREAM_URL=http://transactions-service.fintech-services.svc.cluster.local:8080

# ── Phase 4: Keycloak / Identity ────────────────────────────
# KEYCLOAK_ISSUER=http://keycloak:8080/realms/fintech
# KEYCLOAK_CLIENT_ID=kong
# KEYCLOAK_CLIENT_SECRET=

# ── Phase 7: LLM Provider ────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ── AWS (Phase 1 — EKS via Terraform) ───────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
